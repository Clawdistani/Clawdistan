{
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "node",
    "target": "ES2022",
    "checkJs": true,
    "strict": false,
    "noEmit": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "*": ["*"]
    }
  },
  "include": [
    "*.js",
    "core/**/*.js",
    "api/**/*.js", 
    "client/**/*.js",
    "sdk/**/*.js",
    "tests/**/*.js"
  ],
  "exclude": ["node_modules", "dist"]
}
